# Agent LLMs (Gemma 4 26b — 15 RPM each)
SIMPLE_3T_MODEL=gemma-4-26b-a4b-it
SINGLE_12T_MODEL=gemma-4-26b-a4b-it
SINGLE_12T_CLASSIFY_MODEL=gemma-4-26b-a4b-it
SINGLE_12T_COMPOSE_MODEL=gemma-4-26b-a4b-it
MULTI_CLASSIFY_MODEL=gemma-4-26b-a4b-it
MULTI_COMPOSE_MODEL=gemma-4-26b-a4b-it

# Manager / Critic / Contradiction (Gemma 4 31b — 15 RPM each)
SINGLE_12T_CRITIC_MODEL=gemma-4-31b-it
MULTI_CRITIC_MODEL=gemma-4-31b-it
CONTRADICTION_MODEL=gemma-4-31b-it

# Translation (Gemma 4 26b — 15 RPM)
TRANSLATION_MODEL=gemma-4-26b-a4b-it

# Evaluation (Gemini Flash-Lite — 10 RPM)
EVAL_MODEL=gemini-3.1-flash-lite-preview
RAGAS_MODEL=gemini-3.1-flash-lite-preview

# Tuning
MAX_TOOL_ITERATIONS=15
TRACE_SNIPPET_LENGTH=-1

# Defaults
DEFAULT_AGENT=MultiNode_12T
GOOGLE_API_KEY=your-api-key-here
